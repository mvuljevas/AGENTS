#!/usr/bin/env bash
set -euo pipefail

if [ ! -x "scripts/ai-tools.sh" ]; then
  exit 0
fi

read_kv_file() {
  local file="$1"
  local key="$2"
  [ -f "$file" ] || return 1
  awk -F= -v k="$key" '
    $0 !~ /^[[:space:]]*#/ && $1 == k {
      sub(/^[^=]*=/, "", $0)
      print $0
      exit
    }
  ' "$file"
}

value_for() {
  local key="$1"
  local default_value="$2"
  local value="${!key:-}"
  if [ -z "$value" ]; then
    value="$(read_kv_file ".agents.env" "$key" 2>/dev/null || true)"
  fi
  if [ -z "$value" ]; then
    value="$(read_kv_file ".env" "$key" 2>/dev/null || true)"
  fi
  if [ -z "$value" ]; then
    value="$default_value"
  fi
  printf '%s' "$value"
}

flag="$(value_for AGENTS_AUTO_RUN_ON_COMMIT off)"

case "$flag" in
  on|true|1)
    scripts/ai-tools.sh run-and-stage
    ;;
  *)
    echo "AI tool automation skipped: AGENTS_AUTO_RUN_ON_COMMIT is not on."
    ;;
esac
